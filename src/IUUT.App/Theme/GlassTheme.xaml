<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        IUUT "Telemetry Console" theme tokens + base styles (docs/UI-DESIGN-CONCEPT.md v2).
        Warm-gunmetal graphite, hard 1px grid lines, monospace-forward (Cascadia Code).
        Layered over WPF-UI's Dark theme. Hex is the source of truth in the concept doc §2.

        Implementation rule (doc §2): the legacy x:Key names are KEPT and repointed to the v2
        values, so the view XAML needs no churn. New keys are added at the end of each group.
    -->

    <!-- ============ Fonts ============ -->
    <FontFamily x:Key="MonoFontFamily">Cascadia Code, Cascadia Mono, Consolas, monospace</FontFamily>

    <!-- ============ Colours (warm gunmetal, doc §2) ============ -->
    <!-- legacy keys, repointed -->
    <Color x:Key="SpaceVoidColor">#FF0E0D0C</Color>
    <Color x:Key="SpaceDeepColor">#FF131211</Color>
    <Color x:Key="SpaceNavyColor">#FF1A1816</Color>
    <Color x:Key="AmberCoreColor">#FFF59E0B</Color>
    <Color x:Key="AmberGlowColor">#FFF59E0B</Color>
    <Color x:Key="IonCoreColor">#FF0A84E0</Color>
    <Color x:Key="IonGlowColor">#FF1A8FEF</Color>
    <Color x:Key="TextHiColor">#FFECEAE7</Color>
    <Color x:Key="TextMidColor">#FF9C988F</Color>
    <Color x:Key="TextLowColor">#FF74706A</Color>
    <Color x:Key="StateOkColor">#FF4ADE80</Color>
    <Color x:Key="StateWarnColor">#FFF59E0B</Color>
    <Color x:Key="StateDangerColor">#FFEF4444</Color>

    <!-- v2 surface ramp -->
    <Color x:Key="BgBaseColor">#FF131211</Color>
    <Color x:Key="BgRecessedColor">#FF1A1816</Color>
    <Color x:Key="SurfaceRaisedColor">#FF232120</Color>
    <Color x:Key="SurfaceRaisedTopColor">#FF2A2826</Color>
    <Color x:Key="SurfaceRowColor">#FF2B2926</Color>
    <Color x:Key="SurfaceRowHiColor">#FF353230</Color>
    <Color x:Key="GridLineColor">#FF3C3934</Color>
    <Color x:Key="GridLineStrongColor">#FF4A463F</Color>
    <Color x:Key="AccentColor">#FF0A84E0</Color>
    <Color x:Key="AccentHiColor">#FF1A8FEF</Color>
    <Color x:Key="AccentTextOnColor">#FF06121F</Color>

    <!-- ============ Brushes ============ -->
    <!-- legacy keys, repointed to v2 -->
    <SolidColorBrush x:Key="AmberCoreBrush" Color="{StaticResource AmberCoreColor}" />
    <SolidColorBrush x:Key="IonCoreBrush" Color="{StaticResource IonCoreColor}" />
    <SolidColorBrush x:Key="TextHiBrush" Color="{StaticResource TextHiColor}" />
    <SolidColorBrush x:Key="TextMidBrush" Color="{StaticResource TextMidColor}" />
    <SolidColorBrush x:Key="TextLowBrush" Color="{StaticResource TextLowColor}" />
    <SolidColorBrush x:Key="StateOkBrush" Color="{StaticResource StateOkColor}" />
    <SolidColorBrush x:Key="StateWarnBrush" Color="{StaticResource StateWarnColor}" />
    <SolidColorBrush x:Key="StateDangerBrush" Color="{StaticResource StateDangerColor}" />

    <!-- glass.* legacy names now mean graphite surfaces/lines -->
    <SolidColorBrush x:Key="GlassStrokeBrush" Color="{StaticResource GridLineColor}" />
    <SolidColorBrush x:Key="GlassFillHoverBrush" Color="{StaticResource SurfaceRowHiColor}" />
    <SolidColorBrush x:Key="DataBackdropBrush" Color="{StaticResource SurfaceRowColor}" />

    <!-- v2 brushes -->
    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBaseColor}" />
    <SolidColorBrush x:Key="SurfaceRecessedBrush" Color="{StaticResource BgRecessedColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="SurfaceRowBrush" Color="{StaticResource SurfaceRowColor}" />
    <SolidColorBrush x:Key="SurfaceRowHoverBrush" Color="{StaticResource SurfaceRowHiColor}" />
    <SolidColorBrush x:Key="GridLineBrush" Color="{StaticResource GridLineColor}" />
    <SolidColorBrush x:Key="GridLineStrongBrush" Color="{StaticResource GridLineStrongColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHiBrush" Color="{StaticResource AccentHiColor}" />
    <SolidColorBrush x:Key="AccentTextOnBrush" Color="{StaticResource AccentTextOnColor}" />
    <!-- milled top-edge highlight (doc edge.hi: warm white ~3.5%) -->
    <SolidColorBrush x:Key="EdgeHighlightBrush" Color="#09FFFAF4" />

    <!-- Window background — now a solid graphite (was the orbit gradient) -->
    <SolidColorBrush x:Key="OrbitBackgroundBrush" Color="{StaticResource BgBaseColor}" />

    <!-- Panel surface fill: a hair-lighter top edge → settles to the surface within ~2px,
         giving a milled-edge highlight in a single brush (no extra layer needed). -->
    <LinearGradientBrush x:Key="GlassCardBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource SurfaceRaisedTopColor}" Offset="0" />
        <GradientStop Color="{StaticResource SurfaceRaisedColor}" Offset="0.05" />
        <GradientStop Color="{StaticResource SurfaceRaisedColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- ============ Text styles (Cascadia Code, doc §3) ============ -->
    <Style x:Key="DisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextMidBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextLowBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextMidBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ============ Panel (graphite card) ============ -->
    <!-- legacy key GlassCard: solid graphite, 2px, hard 1px line, no shadow/glow -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassCardBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <!-- ============ Channel light (status dot) ============ -->
    <Style x:Key="ChannelDot" TargetType="Ellipse">
        <Setter Property="Width" Value="7" />
        <Setter Property="Height" Value="7" />
        <Setter Property="Fill" Value="{StaticResource StateOkBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource StateOkColor}" BlurRadius="6" ShadowDepth="0" Opacity="0.7" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Mode tile (large graphite button) ============ -->
    <Style x:Key="ModeTile" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{StaticResource GlassCardBackground}"
                            BorderBrush="{StaticResource GridLineBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="16,14">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceRowHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Lazy Max now shares the standard tile treatment (amber identity retired; doc §0/§2). -->
    <Style x:Key="ModeTileAmber" TargetType="Button" BasedOn="{StaticResource ModeTile}" />

</ResourceDictionary>
