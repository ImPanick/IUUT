<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        IUUT "Glass Console" theme tokens + styles (docs/UI-DESIGN-CONCEPT.md).
        Layered over WPF-UI's Dark theme. Colours are the source of truth in the concept doc.
    -->

    <!-- ============ Colours ============ -->
    <Color x:Key="SpaceVoidColor">#FF060A12</Color>
    <Color x:Key="SpaceDeepColor">#FF0A1020</Color>
    <Color x:Key="SpaceNavyColor">#FF101A30</Color>
    <Color x:Key="AmberCoreColor">#FFFFB24C</Color>
    <Color x:Key="AmberGlowColor">#FFFF9E2C</Color>
    <Color x:Key="IonCoreColor">#FF46D6F2</Color>
    <Color x:Key="IonGlowColor">#FF21B6E6</Color>
    <Color x:Key="TextHiColor">#FFEAF1FB</Color>
    <Color x:Key="TextMidColor">#FF97A6BF</Color>
    <Color x:Key="TextLowColor">#FF5C6B85</Color>
    <Color x:Key="StateOkColor">#FF46E0A0</Color>
    <Color x:Key="StateWarnColor">#FFFFC24C</Color>
    <Color x:Key="StateDangerColor">#FFFF6E7C</Color>

    <!-- ============ Brushes ============ -->
    <SolidColorBrush x:Key="AmberCoreBrush" Color="{StaticResource AmberCoreColor}" />
    <SolidColorBrush x:Key="IonCoreBrush" Color="{StaticResource IonCoreColor}" />
    <SolidColorBrush x:Key="TextHiBrush" Color="{StaticResource TextHiColor}" />
    <SolidColorBrush x:Key="TextMidBrush" Color="{StaticResource TextMidColor}" />
    <SolidColorBrush x:Key="TextLowBrush" Color="{StaticResource TextLowColor}" />
    <SolidColorBrush x:Key="StateOkBrush" Color="{StaticResource StateOkColor}" />
    <SolidColorBrush x:Key="StateWarnBrush" Color="{StaticResource StateWarnColor}" />
    <SolidColorBrush x:Key="StateDangerBrush" Color="{StaticResource StateDangerColor}" />

    <SolidColorBrush x:Key="GlassStrokeBrush" Color="#24FFFFFF" />
    <SolidColorBrush x:Key="GlassFillHoverBrush" Color="#16FFFFFF" />
    <SolidColorBrush x:Key="DataBackdropBrush" Color="#B80B0F18" />

    <!-- Orbit background (window base) + faint instrument glows -->
    <LinearGradientBrush x:Key="OrbitBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0B1322" Offset="0" />
        <GradientStop Color="#FF070B14" Offset="1" />
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="IonGlowBrush" GradientOrigin="0.16,-0.05" Center="0.16,-0.05" RadiusX="0.8" RadiusY="0.7">
        <GradientStop Color="#2921B6E6" Offset="0" />
        <GradientStop Color="#0021B6E6" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="AmberGlowBrush" GradientOrigin="0.92,1.08" Center="0.92,1.08" RadiusX="0.85" RadiusY="0.8">
        <GradientStop Color="#26FF9E2C" Offset="0" />
        <GradientStop Color="#00FF9E2C" Offset="1" />
    </RadialGradientBrush>

    <!-- Glass surface fill: top inner highlight → body tint, in one brush -->
    <LinearGradientBrush x:Key="GlassCardBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#22FFFFFF" Offset="0" />
        <GradientStop Color="#0EFFFFFF" Offset="0.14" />
        <GradientStop Color="#0EFFFFFF" Offset="1" />
    </LinearGradientBrush>

    <!-- ============ Effects ============ -->
    <DropShadowEffect x:Key="CardShadow" Color="#FF000000" BlurRadius="26" ShadowDepth="0" Opacity="0.5" />
    <DropShadowEffect x:Key="IonGlowEffect" Color="{StaticResource IonGlowColor}" BlurRadius="30" ShadowDepth="0" Opacity="0.5" />
    <DropShadowEffect x:Key="AmberGlowEffect" Color="{StaticResource AmberGlowColor}" BlurRadius="34" ShadowDepth="0" Opacity="0.55" />

    <!-- ============ Text styles ============ -->
    <Style x:Key="DisplayText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMidBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextLowBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextMidBrush}" />
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ============ Glass card (container) ============ -->
    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassCardBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <!-- ============ Channel light (status dot) ============ -->
    <Style x:Key="ChannelDot" TargetType="Ellipse">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Fill" Value="{StaticResource StateOkBrush}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="{StaticResource StateOkColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.9" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Mode tile (large glass button) ============ -->
    <Style x:Key="ModeTile" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{StaticResource TextHiBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{StaticResource GlassCardBackground}"
                            BorderBrush="{StaticResource GlassStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="22"
                            Effect="{StaticResource CardShadow}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource GlassFillHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource IonCoreBrush}" />
                            <Setter TargetName="bd" Property="Effect" Value="{StaticResource IonGlowEffect}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Amber identity variant (Lazy Max) -->
    <Style x:Key="ModeTileAmber" TargetType="Button" BasedOn="{StaticResource ModeTile}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{StaticResource GlassCardBackground}"
                            BorderBrush="#66FF9E2C"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="22"
                            Effect="{StaticResource AmberGlowEffect}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource GlassFillHoverBrush}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AmberCoreBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
