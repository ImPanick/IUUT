<UserControl x:Class="IUUT.App.Views.LoadoutsViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Loadouts viewer (master §8.7), read-only. DataContext = LoadoutsViewerViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="LOADOUTS" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding ProfileLabel, StringFormat=Per-prospect loadouts and the gear they carry for “{0}” (read-only).}"
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Summary}" Style="{StaticResource MonoText}" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Reload" Command="{Binding LoadCommand}" VerticalAlignment="Top" Padding="12,4" />
            </Grid>
        </Border>

        <!-- Loadout cards -->
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Loadouts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="14,12" CornerRadius="6"
                                Background="{StaticResource DataBackdropBrush}"
                                BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                            <StackPanel>
                                <!-- Prospect · slot, then state/insured/settled -->
                                <TextBlock Text="{Binding Title}" Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Flags}" Style="{StaticResource MutedText}" Margin="0,1,0,0" />

                                <!-- Envirosuit -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="ENVIROSUIT" Style="{StaticResource LabelText}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding EnviroSuit}" Style="{StaticResource BodyText}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Meta items as wrapping chips -->
                                <TextBlock Text="{Binding ItemsHeader}" Style="{StaticResource LabelText}" Margin="0,10,0,6" />
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="7,3" Margin="0,0,5,5"
                                                    Background="{StaticResource GlassFillHoverBrush}"
                                                    BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                                                <TextBlock Text="{Binding}" Style="{StaticResource MonoText}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                   Margin="2,12,0,0" TextWrapping="Wrap" />
    </Grid>
</UserControl>
