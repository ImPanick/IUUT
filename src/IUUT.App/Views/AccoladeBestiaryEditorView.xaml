<UserControl x:Class="IUUT.App.Views.AccoladeBestiaryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Accolades & Bestiary editor (master §11.7). DataContext = AccoladeBestiaryEditorViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🏅  Accolades &amp; Bestiary" Style="{StaticResource TitleText}" />
                    <TextBlock Text="{Binding ProfileLabel, StringFormat=Grant accolades and set creature-group scan points for “{0}”.}"
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Reload" Command="{Binding LoadCommand}" VerticalAlignment="Top" Padding="12,4" />
            </Grid>
        </Border>

        <!-- Accolades (left) + Bestiary (right) -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Accolades checklist -->
            <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="12" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="4,2,4,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="ACCOLADES" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding AccoladesSummary}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Grant all" Command="{Binding GrantAllAccoladesCommand}" Padding="10,3" Margin="0,0,6,0" />
                            <Button Content="Revoke all" Command="{Binding RevokeAllAccoladesCommand}" Padding="10,3" />
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Accolades}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsGranted, Mode=TwoWay}" Margin="4,5" VerticalContentAlignment="Center">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource BodyText}" TextTrimming="CharacterEllipsis" />
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Bestiary points -->
            <Border Grid.Column="1" Style="{StaticResource GlassCard}" Padding="12" Margin="6,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="4,2,4,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="BESTIARY" Style="{StaticResource LabelText}" />
                            <TextBlock Text="{Binding BestiarySummary}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Max all" Command="{Binding MaxAllBestiaryCommand}" Padding="10,3" VerticalAlignment="Center" />
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Bestiary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Style="{StaticResource BodyText}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                                        <TextBox Grid.Column="1" Width="90" VerticalAlignment="Center" TextAlignment="Right"
                                                 Text="{Binding Points, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status + apply -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="💾  Apply accolades &amp; bestiary" Click="OnApply"
                    Padding="18,8" FontWeight="SemiBold" />
        </Grid>
    </Grid>
</UserControl>
