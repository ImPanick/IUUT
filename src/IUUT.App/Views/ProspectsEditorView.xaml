<UserControl x:Class="IUUT.App.Views.ProspectsEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Prospects editor (master §8.8). DataContext = ProspectsEditorViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header + slot-file picker -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="🗺  Prospects" Style="{StaticResource TitleText}" />
                    <TextBlock Text="Unstick a phantom prospect association to free a stuck character. The world save itself is never touched."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Row="0" Grid.Column="1" Content="Reload" Command="{Binding LoadCommand}" VerticalAlignment="Top" Padding="12,4" />

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="SLOT FILE" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ComboBox MinWidth="300" ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile, Mode=TwoWay}" DisplayMemberPath="Name" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Associations -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="PROSPECT ASSOCIATIONS" Style="{StaticResource LabelText}" Margin="4,2,0,8" />
                <Border Grid.Row="1" CornerRadius="4" Background="{StaticResource DataBackdropBrush}"
                        BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                    <ListBox ItemsSource="{Binding Associations}" SelectedItem="{Binding SelectedAssociation, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource MonoText}" Margin="6,4" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <!-- Status + unstick -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="🔓  Unstick selected" Click="OnUnstick"
                    IsEnabled="{Binding HasSelectedAssociation}" Padding="18,8" FontWeight="SemiBold" />
        </Grid>
    </Grid>
</UserControl>
