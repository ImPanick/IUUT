<UserControl x:Class="IUUT.App.Views.AccountEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Account & Currencies editor (master §11.6). DataContext = AccountEditorViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ACCOUNT &amp; CURRENCIES" Style="{StaticResource LabelText}" />
                    <TextBlock Text="{Binding ProfileLabel, StringFormat=Editing account-wide currencies and blueprints for “{0}”.}"
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="MAX ALL" Command="{Binding MaxAllCurrenciesCommand}" Margin="0,0,6,0" />
                    <Button Content="RELOAD" Command="{Binding LoadCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Currencies -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="12" Margin="0,12,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Currencies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" Padding="14,8" CornerRadius="4"
                                    Background="{StaticResource DataBackdropBrush}"
                                    BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource BodyText}" />
                                        <TextBlock Text="{Binding MetaRow}" Style="{StaticResource MonoText}" Margin="0,1,0,0" />
                                    </StackPanel>
                                    <TextBox Grid.Column="1" Width="150" VerticalAlignment="Center"
                                             Text="{Binding Count, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             TextAlignment="Right" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Blueprints -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="14" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Workshop &amp; prospect blueprints" Style="{StaticResource BodyText}" />
                    <TextBlock Text="{Binding BlueprintsSummary}" Style="{StaticResource MutedText}" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Unlock all blueprints" Click="OnUnlockAllBlueprints"
                        VerticalAlignment="Center" Padding="14,6" />
            </Grid>
        </Border>

        <!-- Status + apply -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="APPLY CURRENCY CHANGES" Style="{StaticResource PrimaryButton}"
                    Click="OnApplyCurrencies" />
        </Grid>
    </Grid>
</UserControl>
