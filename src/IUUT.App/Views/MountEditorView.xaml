<UserControl x:Class="IUUT.App.Views.MountEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Mounts editor (master §8.10). DataContext = MountEditorViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🐎  Mounts" Style="{StaticResource TitleText}" />
                    <TextBlock Text="{Binding ProfileLabel, StringFormat=Rename mounts and set their level for “{0}”. The authoritative stats blob is preserved.}"
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Reload" Command="{Binding LoadCommand}" VerticalAlignment="Top" Padding="12,4" />
            </Grid>
        </Border>

        <!-- Mounts list -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="12" Margin="0,12,0,0">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Mounts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="14,10" CornerRadius="4"
                                        Background="{StaticResource DataBackdropBrush}"
                                        BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding MountType}" Style="{StaticResource MonoText}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0" Width="120" TextTrimming="CharacterEllipsis" />
                                        <TextBox Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock Grid.Column="2" Text="LVL" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBox Grid.Column="3" Width="64" VerticalAlignment="Center" TextAlignment="Right"
                                                 Text="{Binding Level, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"
                           Text="No tamed mounts in this save." TextWrapping="Wrap" TextAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMounts}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Status + apply -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="💾  Apply mount changes" Click="OnApply"
                    Padding="18,8" FontWeight="SemiBold" />
        </Grid>
    </Grid>
</UserControl>
