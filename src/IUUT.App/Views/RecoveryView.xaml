<UserControl x:Class="IUUT.App.Views.RecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">

    <!-- Broken Save Recovery (master §10.1, §11.3). DataContext = RecoveryViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Profile selector + scan -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
                    <TextBlock Text="BROKEN SAVE RECOVERY" Style="{StaticResource LabelText}" />
                    <TextBlock Text="Scan a save for corruption, then restore from backups or rebuild."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>

                <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,10,10,0"
                          ItemsSource="{Binding Slots}"
                          SelectedItem="{Binding SelectedSlot, Mode=TwoWay}"
                          DisplayMemberPath="DisplayLabel" />
                <Button Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Content="SCAN" Command="{Binding ScanCommand}" />
            </Grid>
        </Border>

        <!-- Plan + advisories -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="16" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="RECOVERY PLAN" Style="{StaticResource LabelText}" />

                <!-- Empty state — shown until a scan produces plan lines -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActionLines.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No scan yet" Style="{StaticResource BodyText}"
                               Foreground="{StaticResource TextMidBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Select a save profile above, then choose Scan to build a recovery plan."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding ActionLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource MonoText}" TextWrapping="Wrap" Margin="0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Only partial recovery is possible — rebuilt files lost data; finish in Custom."
                                   Foreground="{StaticResource StateWarnBrush}" TextWrapping="Wrap" Margin="0,12,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PartialRecovery}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding Advisories}" Margin="0,12,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,3">
                                        <ui:SymbolIcon Symbol="Info24" Foreground="{StaticResource IonCoreBrush}" FontSize="12"
                                                       VerticalAlignment="Top" Margin="0,1,6,0" />
                                        <TextBlock Text="{Binding}" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status + repair -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="REPAIR" Style="{StaticResource PrimaryButton}"
                    IsEnabled="{Binding CanRepair}" Click="OnRepair" />
        </Grid>
    </Grid>
</UserControl>
