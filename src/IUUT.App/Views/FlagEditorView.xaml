<UserControl x:Class="IUUT.App.Views.FlagEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Engine Flags editor (master §8.11). DataContext = FlagEditorViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ENGINE FLAGS &amp; MISSIONS" Style="{StaticResource LabelText}" />
                    <TextBlock Text="Character flags (flags_*.dat) — decoded to names. These include map-unlock gates and Mission_* rewards. &quot;Complete missions&quot; sets every mission/story flag."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding SteamId, StringFormat=flags file SteamID: {0}}" Style="{StaticResource MonoText}" Margin="0,6,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Reload" Command="{Binding LoadCommand}" VerticalAlignment="Top" Padding="12,4" />
            </Grid>
        </Border>

        <!-- Flags list + add -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="4,2,4,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ADD FLAG" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ComboBox Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableFlags}" SelectedItem="{Binding SelectedAvailableFlag, Mode=TwoWay}"
                              DisplayMemberPath="Display" IsTextSearchEnabled="True" TextSearch.TextPath="Label" />
                    <Button Grid.Column="2" Content="Add" Command="{Binding AddFlagCommand}" Padding="14,4" Margin="0,0,8,0" />
                    <Button Grid.Column="3" Content="COMPLETE MISSIONS" Command="{Binding CompleteMissionsCommand}" Margin="0,0,8,0" />
                    <Button Grid.Column="4" Content="Remove selected" Command="{Binding RemoveSelectedCommand}" Padding="12,4" />
                </Grid>
                <Border Grid.Row="1" CornerRadius="4" Background="{StaticResource DataBackdropBrush}"
                        BorderBrush="{StaticResource GlassStrokeBrush}" BorderThickness="1">
                    <ListBox ItemsSource="{Binding Flags}" SelectedItem="{Binding SelectedFlag, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" Margin="6,4">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource BodyText}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMission}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource IonCoreBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <!-- Status + apply -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="APPLY TO FLAGS FILE" Style="{StaticResource PrimaryButton}" Click="OnApply" />
        </Grid>
    </Grid>
</UserControl>
