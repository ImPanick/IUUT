<UserControl x:Class="IUUT.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">

    <!-- Home page (master §10.2). DataContext = HomeViewModel (set by the shell's DataTemplate). -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Info panel ===== -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="SAVE ROOT" Style="{StaticResource LabelText}"
                           VerticalAlignment="Center" Margin="0,0,12,6" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SaveRoot, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" Margin="0,0,10,6" />
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="BROWSE…" Click="OnBrowse" Margin="0,0,6,0" />
                    <Button Content="RELOAD" Command="{Binding LoadCommand}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="PROFILE" Style="{StaticResource LabelText}"
                           VerticalAlignment="Center" Margin="0,6,12,6" />
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                          ItemsSource="{Binding Slots}"
                          SelectedItem="{Binding SelectedSlot, Mode=TwoWay}"
                          DisplayMemberPath="DisplayLabel"
                          Margin="0,6,0,6" />

                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal"
                            DataContext="{Binding SelectedSlot}" Margin="0,0,0,6">
                    <TextBlock Text="{Binding SteamId64}" Style="{StaticResource MonoText}" />
                    <TextBlock Text="  ·  " Style="{StaticResource MonoText}" />
                    <TextBlock Style="{StaticResource MonoText}"
                               Text="{Binding CharacterCount, StringFormat={}{0} characters, TargetNullValue=character count unknown}" />
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse VerticalAlignment="Center" Margin="0,0,7,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource ChannelDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SaveRootFound}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource StateDangerBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="Save path" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                        <Ellipse Style="{StaticResource ChannelDot}" VerticalAlignment="Center" Margin="0,0,7,0" />
                        <TextBlock Text="Backups on" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse VerticalAlignment="Center" Margin="0,0,7,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse" BasedOn="{StaticResource ChannelDot}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GameRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource StateWarnBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding GameStatus}" Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Mode tiles ===== -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,10">
            <Button Style="{StaticResource ModeTile}" Margin="0,0,5,0" Command="{Binding OpenRecoveryCommand}">
                <Grid>
                    <TextBlock Text="01" Style="{StaticResource LabelText}" Foreground="{StaticResource TextLowBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top" />
                    <StackPanel>
                        <ui:SymbolIcon Symbol="WrenchScrewdriver24" FontSize="24" HorizontalAlignment="Left"
                                       Foreground="{StaticResource TextMidBrush}" />
                        <TextBlock Text="Broken Save Recovery" Style="{StaticResource TitleText}" Margin="0,12,0,4" />
                        <TextBlock Text="Scan, diagnose and repair a corrupt or non-loading save."
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="OPEN →" Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource IonCoreBrush}" Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Style="{StaticResource ModeTileAmber}" Margin="5,0,5,0" Click="OnLazyMax">
                <Grid>
                    <TextBlock Text="02" Style="{StaticResource LabelText}" Foreground="{StaticResource TextLowBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top" />
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Flash24" FontSize="24" HorizontalAlignment="Left"
                                       Foreground="{StaticResource TextMidBrush}" />
                        <TextBlock Text="Lazy Max" Style="{StaticResource TitleText}" Margin="0,12,0,4" />
                        <TextBlock Text="One click: max talents, currencies, accolades and bestiary."
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="ONE-CLICK · BACKED UP" Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource AmberCoreBrush}" Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Style="{StaticResource ModeTile}" Margin="5,0,5,0" Command="{Binding OpenCustomCommand}">
                <Grid>
                    <TextBlock Text="03" Style="{StaticResource LabelText}" Foreground="{StaticResource TextLowBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top" />
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Options24" FontSize="24" HorizontalAlignment="Left"
                                       Foreground="{StaticResource TextMidBrush}" />
                        <TextBlock Text="Custom Editor" Style="{StaticResource TitleText}" Margin="0,12,0,4" />
                        <TextBlock Text="Fine-grained control — currencies, talents, stash and more."
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="OPEN →" Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource IonCoreBrush}" Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </Button>

            <Button Style="{StaticResource ModeTile}" Margin="5,0,0,0" Command="{Binding OpenGameTunerCommand}">
                <Grid>
                    <TextBlock Text="04" Style="{StaticResource LabelText}" Foreground="{StaticResource TextLowBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Top" />
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Settings24" FontSize="24" HorizontalAlignment="Left"
                                       Foreground="{StaticResource TextMidBrush}" />
                        <TextBlock Text="Game Tuner" Style="{StaticResource TitleText}" Margin="0,12,0,4" />
                        <TextBlock Text="Engine.ini tweaks — buff FPS, fog, quality scalars, frame cap."
                                   Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                        <TextBlock Text="OPEN →" Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource IonCoreBrush}" Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </Button>
        </UniformGrid>

        <!-- ===== Status bar ===== -->
        <StackPanel Grid.Row="2">
            <Rectangle Height="1" Margin="0,0,0,9" Fill="{StaticResource GridLineBrush}" />
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Style="{StaticResource ChannelDot}" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <TextBlock Text="Catalogs loaded" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MonoText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
