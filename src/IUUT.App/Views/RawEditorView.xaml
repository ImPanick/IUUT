<UserControl x:Class="IUUT.App.Views.RawEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Advanced / Raw editor (master §10.4). DataContext = RawEditorViewModel. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header + file picker -->
        <Border Grid.Row="0" Style="{StaticResource GlassCard}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="🧾  Advanced / Raw" Style="{StaticResource TitleText}" />
                    <TextBlock Text="View and edit any save JSON file directly. Saving re-parses the text — malformed JSON is rejected and the original is kept. A backup is taken on every save."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Row="0" Grid.Column="1" Content="Reload" Command="{Binding LoadCommand}" VerticalAlignment="Top" Padding="12,4" />

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="FILE" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <ComboBox MinWidth="300" ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile, Mode=TwoWay}" DisplayMemberPath="Name" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Raw text -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="6" Margin="0,12,0,0">
            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12"
                     Background="Transparent" BorderThickness="0" />
        </Border>

        <!-- Status + save -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
            <Button Grid.Column="1" Content="💾  Save file" Click="OnSave"
                    IsEnabled="{Binding HasFile}" Padding="18,8" FontWeight="SemiBold" />
        </Grid>
    </Grid>
</UserControl>
